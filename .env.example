# Milvus 连接配置
KB_MILVUS_URI=http://localhost:19530
KB_MILVUS_TOKEN=
KB_MILVUS_DB=default
KB_MILVUS_COLLECTION=knowledge_base

# Milvus schema 字段名（默认与 milvus-cli.py 一致，通常无需改）
KB_MILVUS_DENSE_FIELD=dense_vector
KB_MILVUS_SPARSE_FIELD=sparse_vector
KB_MILVUS_TEXT_FIELD=chunk_text

# 检索结果字段（multi-query-search 依赖 kind / chunk_id / question_id 三个字段做 RRF 与去重）
KB_MILVUS_OUTPUT_FIELDS=kind,doc_id,chunk_id,question_id,title,section_path,source,url,summary

# Embedding provider
# 可选值: default, sentence-transformer, openai, bge-m3
# 默认 bge-m3：dense 1024 维 + sparse，能启动 hybrid 检索与合成 QA 召回。
# 首次启动会下载约 1.4 GB BGE-M3 模型到 ~/.cache/huggingface/。
KB_EMBEDDING_PROVIDER=bge-m3
# 留空时由 provider 自动决定（bge-m3 -> hybrid；其他 -> dense）
KB_RETRIEVAL_MODE=

# 模型路径
KB_SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
KB_BGEM3_MODEL_PATH=BAAI/bge-m3
# CPU 可跑；有 GPU 时设 cuda 显著加速 BGE-M3 向量化
KB_EMBEDDING_DEVICE=cpu

# OpenAI dense embedding（备用，需要时再切）
OPENAI_API_KEY=
KB_OPENAI_EMBEDDING_MODEL=text-embedding-3-large
KB_OPENAI_EMBEDDING_DIMENSIONS=3072

# MinerU 文档转换配置
# MinerU 可执行文件路径。留空则从 PATH 找 `mineru`。
# 当 MinerU 与 Milvus 的 transformers 版本冲突时，可指向独立环境中的 mineru。
KB_MINERU_BIN=
# MinerU 启动前最低空闲 GPU 显存（MB）。默认 14000（14 GB）。
# 16 GB 显卡单文件峰值约 14 GB，设 0 可跳过检测（不推荐）。
KB_MINERU_VRAM_LIMIT_MB=14000

# 更新间隔（小时）
UPDATE_INTERVAL_HOURS=24

# RRF 参数（multi-query-search 与 Milvus 内部 hybrid_search 的默认 k）
RRF_K=60
TOP_K=10
